# ─── AWS Infrastructure ──────────────────────────────────────────────────────
# The API Gateway URL pointing to your chatbot Lambda function
NEXT_PUBLIC_CHATBOT_API_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/prod/chat

# ─── LLM Provider (Lambda env vars — set in AWS Console or CDK) ──────────────
# Provider-agnostic: swap these to change LLM without touching code

# Kimi K2 (Moonshot AI) — default
LLM_BASE_URL=https://api.moonshot.cn/v1
LLM_MODEL=moonshot-v1-128k
LLM_API_KEY=sk-your-moonshot-api-key

# ── Alternatives (uncomment to switch) ──────────────────────────────────────
# OpenAI
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-your-openai-key

# Anthropic (Claude) — via direct API
# LLM_BASE_URL=https://api.anthropic.com/v1
# LLM_MODEL=claude-sonnet-4-6
# LLM_API_KEY=sk-ant-your-key

# AWS Bedrock (Claude via boto3 — different Lambda setup, see aws/README.md)
# LLM_PROVIDER=bedrock
# LLM_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
